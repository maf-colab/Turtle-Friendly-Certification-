<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Turtle Friendly Certification Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <style>
    html { scroll-behavior: smooth; }
    body { margin: 0; background: #020617; }
    @media print {
      .no-print { display: none !important; }
      body { background: #020617 !important; }
    }
  </style>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useMemo, useState } = React;

    const ICONS = {
      Shield: '🛡️',
      Camera: '📷',
      ClipboardCheck: '✅',
      BarChart3: '📊',
      Waves: '🌊',
      FileText: '📄',
      TrendingUp: '📈',
      Globe: '🌍',
      Award: '🏆',
      Zap: '⚡',
      Users: '👥',
      LayoutDashboard: '▦',
      Target: '◎',
      ArrowUpRight: '↗',
      HelpCircle: '?',
      Menu: '☰',
      X: '×',
    };

    const DIMENSIONS = [
      { id: 'd1', name: 'Habitat Protection', weight: 30, score: 65, color: '#3b82f6', icon: 'Waves' },
      { id: 'd2', name: 'Infrastructure', weight: 20, score: 85, color: '#10b981', icon: 'Shield' },
      { id: 'd3', name: 'Guest Experience', weight: 15, score: 40, color: '#f59e0b', icon: 'Camera' },
      { id: 'd4', name: 'Community', weight: 15, score: 20, color: '#8b5cf6', icon: 'ClipboardCheck' },
      { id: 'd5', name: 'Data & Monitoring', weight: 10, score: 90, color: '#ec4899', icon: 'BarChart3' },
      { id: 'd6', name: 'ESG Governance', weight: 10, score: 100, color: '#06b6d4', icon: 'FileText' },
    ];

    const PERFORMANCE_TREND = [
      { month: 'Jan', revenue: 4200, compliance: 45 },
      { month: 'Feb', revenue: 4500, compliance: 48 },
      { month: 'Mar', revenue: 5100, compliance: 55 },
      { month: 'Apr', revenue: 5900, compliance: 62 },
      { month: 'May', revenue: 7800, compliance: 71 },
      { month: 'Jun', revenue: 8400, compliance: 74 },
    ];

    const AUDIT_LOG = [
      { id: 'a1', status: 'completed', title: 'Q2 Lighting Audit', date: 'May 14', user: 'Verified Auditor' },
      { id: 'a2', status: 'pending', title: 'Nesting Monitoring', date: 'Tonight', user: 'Beach Ops' },
      { id: 'a3', status: 'upcoming', title: 'Staff Training', date: 'Jun 05', user: 'HR Director' },
    ];

    const NAV_ITEMS = [
      { id: 'overview', label: 'Overview', icon: 'LayoutDashboard' },
      { id: 'targets', label: 'Targets', icon: 'Target' },
      { id: 'analytics', label: 'Analytics', icon: 'BarChart3' },
      { id: 'market', label: 'Market', icon: 'Globe' },
      { id: 'team', label: 'Team', icon: 'Users' },
    ];

    function Icon({ name, className = '' }) {
      return <span className={`inline-flex h-5 w-5 items-center justify-center leading-none ${className}`} aria-hidden="true">{ICONS[name] || '•'}</span>;
    }

    function getScoreStatus(score) {
      if (score >= 90) return { label: 'Excellent', color: 'text-emerald-400' };
      if (score >= 70) return { label: 'Strong', color: 'text-blue-400' };
      if (score >= 50) return { label: 'Improving', color: 'text-amber-400' };
      return { label: 'Critical Gap', color: 'text-rose-400' };
    }

    function calculateWeightedScore(dimensions) {
      const totalWeight = dimensions.reduce((sum, dimension) => sum + Number(dimension.weight || 0), 0);
      if (totalWeight <= 0) return 0;
      return dimensions.reduce((sum, dimension) => {
        const score = Math.max(0, Math.min(100, Number(dimension.score || 0)));
        const weight = Math.max(0, Number(dimension.weight || 0));
        return sum + score * weight;
      }, 0) / totalWeight;
    }

    function formatScoreParts(score) {
      const safeScore = Number.isFinite(score) ? score : 0;
      const [integerPart, decimalPart = '0'] = safeScore.toFixed(1).split('.');
      return { integerPart, decimalPart };
    }

    function GlassCard({ children, className = '', title, subtitle, icon, badge }) {
      return (
        <section className={`rounded-2xl border border-slate-800 bg-slate-950/80 p-5 shadow-xl transition-all hover:border-blue-500/50 ${className}`}>
          {(title || icon || badge) ? (
            <div className="mb-4 flex items-start justify-between gap-4">
              <div className="flex flex-col gap-1">
                <div className="flex items-center gap-2">
                  {icon ? <Icon name={icon} className="text-blue-400" /> : null}
                  {title ? <h3 className="text-sm font-bold tracking-tight text-white">{title}</h3> : null}
                </div>
                {subtitle ? <p className="max-w-xl text-xs font-medium leading-snug text-slate-500">{subtitle}</p> : null}
              </div>
              {badge ? (
                <span className="rounded-full border border-blue-500/20 bg-blue-500/10 px-2 py-0.5 text-[9px] font-black uppercase tracking-widest text-blue-400">
                  {badge}
                </span>
              ) : null}
            </div>
          ) : null}
          {children}
        </section>
      );
    }

    function KPIMetric({ label, value, trend, suffix = '' }) {
      const hasTrend = typeof trend === 'number' && Number.isFinite(trend);
      const isPositive = hasTrend ? trend >= 0 : false;

      return (
        <div className="flex flex-col">
          <span className="mb-1 text-[9px] font-black uppercase tracking-widest text-slate-500">{label}</span>
          <div className="flex items-baseline gap-1.5">
            <span className="text-xl font-black text-white">{value}{suffix}</span>
            {hasTrend ? (
              <span className={`rounded-md px-1.5 py-0.5 text-[9px] font-bold ${isPositive ? 'bg-emerald-400/5 text-emerald-400' : 'bg-rose-400/5 text-rose-400'}`}>
                {isPositive ? '+' : ''}{trend}%
              </span>
            ) : null}
          </div>
        </div>
      );
    }

    function SimpleAreaChart({ data }) {
      const width = 760;
      const height = 280;
      const padding = { top: 24, right: 28, bottom: 36, left: 48 };
      const maxRevenue = Math.max(...data.map((d) => d.revenue));
      const minRevenue = Math.min(...data.map((d) => d.revenue));
      const maxCompliance = 100;

      const x = (index) => padding.left + (index * (width - padding.left - padding.right)) / (data.length - 1);
      const yRevenue = (value) => padding.top + ((maxRevenue - value) / (maxRevenue - minRevenue || 1)) * (height - padding.top - padding.bottom);
      const yCompliance = (value) => padding.top + ((maxCompliance - value) / maxCompliance) * (height - padding.top - padding.bottom);

      const revenuePoints = data.map((d, i) => `${x(i)},${yRevenue(d.revenue)}`).join(' ');
      const compliancePoints = data.map((d, i) => `${x(i)},${yCompliance(d.compliance)}`).join(' ');
      const areaPoints = `${padding.left},${height - padding.bottom} ${revenuePoints} ${width - padding.right},${height - padding.bottom}`;

      return (
        <div className="h-[280px] w-full overflow-hidden">
          <svg viewBox={`0 0 ${width} ${height}`} className="h-full w-full" role="img" aria-label="Eco revenue and compliance trend chart">
            <defs>
              <linearGradient id="revenueFill" x1="0" y1="0" x2="0" y2="1">
                <stop offset="5%" stopColor="#3b82f6" stopOpacity="0.40" />
                <stop offset="95%" stopColor="#3b82f6" stopOpacity="0" />
              </linearGradient>
            </defs>

            {[0, 1, 2, 3].map((line) => {
              const y = padding.top + line * ((height - padding.top - padding.bottom) / 3);
              return <line key={line} x1={padding.left} x2={width - padding.right} y1={y} y2={y} stroke="#1e293b" strokeDasharray="3 3" />;
            })}

            <polygon points={areaPoints} fill="url(#revenueFill)" />
            <polyline points={revenuePoints} fill="none" stroke="#3b82f6" strokeWidth="4" strokeLinecap="round" strokeLinejoin="round" />
            <polyline points={compliancePoints} fill="none" stroke="#10b981" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round" />

            {data.map((d, i) => (
              <g key={d.month}>
                <text x={x(i)} y={height - 12} textAnchor="middle" fill="#64748b" fontSize="12" fontWeight="700">{d.month}</text>
                <circle cx={x(i)} cy={yRevenue(d.revenue)} r="4" fill="#3b82f6" />
                <circle cx={x(i)} cy={yCompliance(d.compliance)} r="4" fill="#10b981" />
              </g>
            ))}

            <text x={padding.left} y="16" fill="#64748b" fontSize="11" fontWeight="800">Revenue</text>
            <text x={width - padding.right} y="16" fill="#64748b" fontSize="11" fontWeight="800" textAnchor="end">Compliance</text>
          </svg>
        </div>
      );
    }

    function Sidebar({ activeTab, setActiveTab }) {
      const [isOpen, setIsOpen] = useState(false);

      return (
        <nav className="no-print relative border-b border-slate-800 bg-slate-950 md:min-h-screen md:w-24 md:border-b-0 md:border-r" aria-label="Primary navigation">
          <div className="flex items-center justify-between p-4 md:min-h-screen md:flex-col md:gap-10 md:px-0 md:py-8">
            <div className="flex items-center gap-3 md:flex-col">
              <div className="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600 shadow-lg shadow-blue-600/20">
                <Icon name="Shield" />
              </div>
              <span className="text-xs font-black uppercase tracking-widest text-white md:hidden">TFC Hub</span>
            </div>

            <button
              type="button"
              className="rounded-xl border border-slate-800 p-2 text-slate-300 md:hidden"
              aria-expanded={isOpen}
              aria-label="Toggle navigation menu"
              onClick={() => setIsOpen((value) => !value)}
            >
              <Icon name={isOpen ? 'X' : 'Menu'} />
            </button>

            <div className={`${isOpen ? 'absolute left-0 right-0 top-full z-20 grid bg-slate-950 p-4 shadow-xl' : 'hidden'} gap-3 md:static md:z-auto md:flex md:flex-1 md:flex-col md:bg-transparent md:p-0 md:shadow-none`}>
              {NAV_ITEMS.map(({ id, label, icon }) => {
                const selected = activeTab === id;
                return (
                  <button
                    key={id}
                    type="button"
                    className={`flex items-center gap-3 rounded-xl p-3 text-left text-sm font-bold transition-all md:justify-center ${selected ? 'bg-slate-800 text-white shadow-md' : 'text-slate-500 hover:bg-slate-900 hover:text-blue-400'}`}
                    aria-current={selected ? 'page' : undefined}
                    onClick={() => {
                      setActiveTab(id);
                      setIsOpen(false);
                    }}
                  >
                    <Icon name={icon} />
                    <span className="md:sr-only">{label}</span>
                  </button>
                );
              })}
            </div>

            <div className="hidden md:mt-auto md:flex md:flex-col md:gap-6">
              <div className="h-8 w-8 rounded-full border border-slate-700 bg-slate-800" role="img" aria-label="User profile" />
            </div>
          </div>
        </nav>
      );
    }

    function Dashboard() {
      const [activeTab, setActiveTab] = useState('overview');
      const aggregateScore = useMemo(() => calculateWeightedScore(DIMENSIONS), []);
      const { integerPart, decimalPart } = formatScoreParts(aggregateScore);
      const scoreLabel = aggregateScore >= 85 ? 'Leadership' : aggregateScore >= 70 ? 'Advanced Practitioner' : aggregateScore >= 50 ? 'Improvement Required' : 'At Risk';

      return (
        <div className="min-h-screen bg-slate-950 text-slate-200 selection:bg-blue-500/30">
          <div className="flex min-h-screen flex-col md:flex-row">
            <Sidebar activeTab={activeTab} setActiveTab={setActiveTab} />

            <main className="flex-1 p-4 md:p-10">
              <header className="mb-10 flex flex-col items-start justify-between gap-6 border-b border-slate-800/50 pb-8 xl:flex-row xl:items-center">
